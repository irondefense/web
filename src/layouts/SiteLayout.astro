---
interface Props {
  title: string;
  description?: string;
  bodyClass?: string;
}

const { title, description = "MalReports", bodyClass } = Astro.props;
---

<!doctype html>
<html lang="pl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <slot name="head" />
    <style is:global>
      @import url("https://fonts.googleapis.com/css2?family=Chakra+Petch:wght@500;600;700&family=JetBrains+Mono:wght@400;500;700;800&family=Manrope:wght@400;500;600;700;800&display=swap");

      :root {
        --font-display: "Chakra Petch", sans-serif;
        --font-body: "Manrope", sans-serif;
        --font-mono: "JetBrains Mono", monospace;
      }

      * {
        box-sizing: border-box;
      }

      html {
        font-family: var(--font-body);
        scrollbar-gutter: stable;
      }

      body {
        margin: 0;
        min-height: 100vh;
        font-family: var(--font-body);
      }

      h1,
      h2,
      h3,
      h4,
      h5,
      h6 {
        font-family: var(--font-display);
      }

      code,
      pre,
      .mono {
        font-family: var(--font-mono);
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      img {
        max-width: 100%;
        height: auto;
      }

      ::selection {
        background: rgba(110, 142, 164, 0.24);
      }
    </style>
  </head>
  <body class={bodyClass}>
    <slot />
  </body>
</html>
