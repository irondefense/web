---
import TopNav from "../components/home/TopNav.astro";
import LandingLayout from "./LandingLayout.astro";

interface Props {
  title: string;
  description?: string;
  repoUrl: string;
}

const { title, description, repoUrl } = Astro.props;
---

<LandingLayout title={title} description={description}>
  <TopNav repoUrl={repoUrl} />

  <style is:global>
    .report-page {
      padding: 3rem 0 5.5rem;
    }

    .report-hero {
      display: grid;
      gap: 1.8rem;
      max-width: 70rem;
      margin: 0 auto;
      padding: clamp(1.6rem, 3vw, 2.6rem);
      border: 1px solid rgba(158, 184, 201, 0.12);
      background:
        radial-gradient(circle at top right, rgba(158, 184, 201, 0.08), transparent 22rem),
        linear-gradient(180deg, rgba(40, 45, 52, 0.88), rgba(31, 35, 41, 0.76));
      box-shadow:
        0 24px 54px rgba(0, 0, 0, 0.18),
        inset 0 1px 0 rgba(255, 255, 255, 0.04);
    }

    .report-kicker {
      display: inline-flex;
      align-items: center;
      gap: 0.9rem;
      margin: 0;
      color: var(--landing-accent);
      font-family: var(--font-mono);
      font-size: 0.94rem;
      letter-spacing: 0.22em;
      text-transform: uppercase;
    }

    .report-kicker::before {
      content: "";
      width: 2.4rem;
      height: 2px;
      background: var(--landing-accent);
    }

    .report-title {
      margin: 0;
      color: var(--landing-text-strong);
      max-width: 16ch;
      font-family: var(--font-body);
      font-size: clamp(2.5rem, 5.8vw, 4.5rem);
      font-weight: 800;
      line-height: 1;
      letter-spacing: -0.05em;
      text-wrap: balance;
    }

    .report-description {
      max-width: 48rem;
      margin: 0;
      padding-left: 1.2rem;
      border-left: 3px solid var(--landing-accent);
      color: #c2ced8;
      font-size: 1.16rem;
      line-height: 1.9;
    }

    .report-topbar {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;
      padding-bottom: 0.4rem;
      border-bottom: 1px solid rgba(158, 184, 201, 0.12);
    }

    .back-link {
      color: var(--landing-accent);
      font-family: var(--font-mono);
      font-size: 0.92rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    .lang-switch {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      flex-wrap: wrap;
      padding: 0.3rem;
      border: 1px solid rgba(158, 184, 201, 0.1);
      background: rgba(255, 255, 255, 0.035);
    }

    .lang-label {
      color: #6f7e8c;
      font-family: var(--font-mono);
      font-size: 0.82rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
    }

    .lang-link {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 2.2rem;
      padding: 0 0.85rem;
      border: 0;
      background: transparent;
      color: var(--landing-text-strong);
      font-family: var(--font-mono);
      font-size: 0.86rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    .lang-link.active {
      color: var(--landing-accent);
      background: rgba(158, 184, 201, 0.14);
      box-shadow: inset 0 0 0 1px rgba(158, 184, 201, 0.16);
    }

    .lang-link.disabled {
      opacity: 0.45;
      pointer-events: none;
    }

    .report-info-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 1rem;
      padding-top: 0.3rem;
    }

    .info-card {
      display: grid;
      grid-template-columns: 2.9rem minmax(0, 1fr);
      gap: 0.95rem;
      align-items: center;
      padding: 0.55rem 0;
      min-height: 100%;
      border: 0;
      background: transparent;
    }

    .info-card-icon {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 2.9rem;
      height: 2.9rem;
      border: 1px solid rgba(158, 184, 201, 0.1);
      background: rgba(255, 255, 255, 0.015);
      color: var(--landing-accent);
    }

    .info-card-icon svg {
      width: 1.08rem;
      height: 1.08rem;
    }

    .info-card-copy {
      min-width: 0;
      display: grid;
      gap: 0.2rem;
    }

    .info-card-label {
      display: block;
      color: #6f7e8c;
      font-family: var(--font-mono);
      font-size: 0.76rem;
      letter-spacing: 0.14em;
      text-transform: uppercase;
    }

    .info-card-value {
      display: block;
      color: var(--landing-text-strong);
      font-size: 1.02rem;
      line-height: 1.5;
    }

    .report-prose {
      position: relative;
      max-width: 62rem;
      margin: 2.3rem auto 0;
      padding: clamp(2rem, 4vw, 3.4rem);
      border: 1px solid rgba(158, 184, 201, 0.12);
      background:
        linear-gradient(180deg, rgba(43, 48, 56, 0.82), rgba(32, 36, 42, 0.82)),
        rgba(34, 38, 44, 0.72);
      box-shadow:
        0 26px 60px rgba(0, 0, 0, 0.16),
        inset 0 1px 0 rgba(255, 255, 255, 0.04);
    }

    .report-prose::before {
      content: "";
      position: absolute;
      top: 1.1rem;
      left: 1.25rem;
      width: 3.3rem;
      height: 3px;
      border-radius: 999px;
      background: var(--landing-accent);
    }

    .report-prose :global(h1),
    .report-prose :global(h2),
    .report-prose :global(h3),
    .report-prose :global(h4) {
      color: var(--landing-text-strong);
      font-family: var(--font-body);
      font-weight: 800;
      line-height: 1.08;
      letter-spacing: -0.03em;
      margin: 2.8rem 0 1rem;
    }

    .report-prose :global(h1:first-child),
    .report-prose :global(h2:first-child) {
      margin-top: 0;
    }

    .report-prose :global(h2) {
      padding-top: 1.35rem;
      border-top: 1px solid rgba(158, 184, 201, 0.12);
      font-size: clamp(1.9rem, 4vw, 2.45rem);
    }

    .report-prose :global(h3) {
      font-size: clamp(1.35rem, 3vw, 1.75rem);
    }

    .report-prose :global(p),
    .report-prose :global(li) {
      color: #d1d9e0;
      font-size: 1.12rem;
      line-height: 2.06;
    }

    .report-prose :global(p:first-of-type) {
      color: #e7edf2;
      font-size: 1.18rem;
      line-height: 2;
    }

    .report-prose :global(p + p) {
      margin-top: 1.3rem;
    }

    .report-prose :global(ul),
    .report-prose :global(ol) {
      padding-left: 1.4rem;
    }

    .report-prose :global(li + li) {
      margin-top: 0.75rem;
    }

    .report-prose :global(blockquote) {
      margin: 1.8rem 0;
      padding: 1.1rem 1.2rem 1.1rem 1.25rem;
      border-left: 3px solid var(--landing-accent);
      background: rgba(255, 255, 255, 0.04);
    }

    .report-prose :global(hr) {
      border: 0;
      border-top: 1px solid var(--landing-line);
      margin: 2rem 0;
    }

    .report-prose :global(a) {
      color: var(--landing-accent);
      text-underline-offset: 0.16em;
    }

    .report-prose :global(table) {
      width: 100%;
      border-collapse: collapse;
      margin: 1.6rem 0;
      font-size: 0.98rem;
    }

    .report-prose :global(th),
    .report-prose :global(td) {
      padding: 0.85rem 0.9rem;
      border: 1px solid rgba(158, 184, 201, 0.12);
      text-align: left;
      vertical-align: top;
    }

    .report-prose :global(th) {
      color: var(--landing-text-strong);
      background: rgba(255, 255, 255, 0.04);
    }

    .report-prose :global(code:not(pre code)) {
      padding: 0.2rem 0.42rem;
      border: 1px solid rgba(158, 184, 201, 0.14);
      border-radius: 0.3rem;
      background: rgba(255, 255, 255, 0.04);
      font-family: var(--font-mono);
      font-size: 0.92em;
    }

    .report-prose :global(pre) {
      position: relative;
      margin: 1.9rem 0;
      overflow-x: auto;
    }

    .report-prose :global(pre.shiki) {
      padding: 3.1rem 1.3rem 1.3rem !important;
      border: 1px solid rgba(158, 184, 201, 0.1);
      background:
        linear-gradient(180deg, rgba(18, 22, 28, 0.98), rgba(15, 19, 24, 1)) !important;
      box-shadow:
        0 20px 42px rgba(0, 0, 0, 0.2),
        inset 0 1px 0 rgba(255, 255, 255, 0.04);
    }

    .report-prose :global(pre.shiki)::before {
      content: "Shiki snippet";
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      display: flex;
      align-items: center;
      height: 2.2rem;
      padding: 0 1rem 0 3.9rem;
      border-bottom: 1px solid rgba(158, 184, 201, 0.08);
      color: #8ea5b5;
      font-family: var(--font-mono);
      font-size: 0.76rem;
      font-weight: 700;
      letter-spacing: 0.14em;
      text-transform: uppercase;
    }

    .report-prose :global(pre.shiki)::after {
      content: "";
      position: absolute;
      top: 0.78rem;
      left: 1rem;
      width: 2rem;
      height: 0.55rem;
      border-radius: 999px;
      background:
        radial-gradient(circle, #ff8c8c 0 42%, transparent 48%),
        radial-gradient(circle, #f8b35f 0 42%, transparent 48%),
        radial-gradient(circle, #9eb8c9 0 42%, transparent 48%);
      background-size: 0.55rem 0.55rem;
      background-position: 0 0, 0.72rem 0, 1.44rem 0;
      background-repeat: no-repeat;
    }

    .report-prose :global(img) {
      display: block;
      margin: 1.8rem auto;
      border: 1px solid rgba(158, 184, 201, 0.14);
      box-shadow: 0 16px 28px rgba(0, 0, 0, 0.16);
    }

    @media (max-width: 980px) {
      .report-info-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
    }

    @media (max-width: 760px) {
      .report-page {
        padding-top: 2rem;
      }

      .report-topbar {
        align-items: flex-start;
        flex-direction: column;
      }

      .report-info-grid {
        grid-template-columns: 1fr;
      }

      .info-card {
        padding: 0.15rem 0;
        background: transparent;
      }

      .report-prose {
        margin-top: 1.6rem;
        padding: 1.7rem 1.05rem 2rem;
      }

      .report-prose :global(p),
      .report-prose :global(li) {
        font-size: 1.04rem;
        line-height: 1.98;
      }
    }
  </style>

  <main class="report-page">
    <slot />
  </main>
</LandingLayout>
