---
interface Props {
  title: string;
  description?: string;
}

const { title, description = "Zbior raportow Markdown." } = Astro.props;
---

<!doctype html>
<html lang="pl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <style>
      :root {
        color-scheme: light;
        font-family: "IBM Plex Sans", system-ui, sans-serif;
        line-height: 1.6;
        color: #171717;
        background: #f7f4ec;
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        min-height: 100vh;
        background:
          radial-gradient(circle at top, rgba(186, 162, 114, 0.25), transparent 32rem),
          #f7f4ec;
      }

      a {
        color: #0f4c5c;
      }

      main {
        width: min(52rem, calc(100vw - 2rem));
        margin: 0 auto;
        padding: 3rem 0 5rem;
      }

      header {
        margin-bottom: 3rem;
      }

      h1,
      h2,
      h3 {
        line-height: 1.15;
      }

      .eyebrow {
        margin: 0 0 0.75rem;
        font-size: 0.8rem;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: #6b665b;
      }

      .card-list {
        display: grid;
        gap: 1rem;
      }

      .card {
        padding: 1.25rem;
        border: 1px solid rgba(23, 23, 23, 0.12);
        border-radius: 1rem;
        background: rgba(255, 255, 255, 0.72);
        backdrop-filter: blur(8px);
      }

      .card h2 {
        margin: 0 0 0.4rem;
      }

      .meta {
        margin: 0;
        color: #5a564c;
        font-size: 0.95rem;
      }

      article {
        padding: 2rem;
        border-radius: 1.25rem;
        background: rgba(255, 255, 255, 0.82);
        border: 1px solid rgba(23, 23, 23, 0.12);
      }

      article img {
        max-width: 100%;
        height: auto;
      }

      code {
        font-family: "IBM Plex Mono", ui-monospace, monospace;
      }
    </style>
  </head>
  <body>
    <main>
      <slot />
    </main>
  </body>
</html>
