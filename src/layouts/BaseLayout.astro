---
import SiteLayout from "./SiteLayout.astro";

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Zbior raportow Markdown." } = Astro.props;
---

<SiteLayout title={title} description={description}>
  <style>
      :root {
        color-scheme: light;
        line-height: 1.6;
        color: #171717;
        background: #f7f4ec;
      }

      body {
        margin: 0;
        min-height: 100vh;
        background:
          radial-gradient(circle at top, rgba(151, 168, 181, 0.18), transparent 32rem),
          #f1eee8;
        color: #1c232a;
      }

      a {
        color: #355066;
      }

      main {
        width: min(52rem, calc(100vw - 2rem));
        margin: 0 auto;
        padding: 3rem 0 5rem;
      }

      header {
        margin-bottom: 3rem;
      }

      h1,
      h2,
      h3 {
        line-height: 1.15;
        font-family: var(--font-display);
      }

      .eyebrow {
        margin: 0 0 0.75rem;
        font-family: var(--font-mono);
        font-size: 0.8rem;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: #69788a;
      }

      .card-list {
        display: grid;
        gap: 1rem;
      }

      .card {
        padding: 1.25rem;
        border: 1px solid rgba(28, 35, 42, 0.12);
        border-radius: 1rem;
        background: rgba(255, 255, 255, 0.78);
        backdrop-filter: blur(8px);
      }

      .card h2 {
        margin: 0 0 0.4rem;
      }

      .meta {
        margin: 0;
        color: #6d7680;
        font-size: 0.95rem;
      }

      article {
        padding: 2rem;
        border-radius: 1.25rem;
        background: rgba(255, 255, 255, 0.86);
        border: 1px solid rgba(28, 35, 42, 0.12);
      }

      article img {
        max-width: 100%;
        height: auto;
      }

      code {
        font-family: var(--font-mono);
      }
  </style>

  <main>
    <slot />
  </main>
</SiteLayout>
