---
import ArchivePage from "../../../components/reports/ArchivePage.astro";
import { locales, type Locale } from "../../../lib/i18n";
import { getLocalizedPath, getLocalizedSegment } from "../../../lib/routes";

export async function getStaticPaths() {
  return locales.map((locale) => ({
    params: {
      locale,
      reportsSegment: getLocalizedSegment("reports", locale),
    },
    props: { locale },
  }));
}

const { locale } = Astro.props as { locale: Locale };
const englishArchiveHref = getLocalizedPath("en", "reports");

if (locale === "en") {
  return Astro.redirect(englishArchiveHref);
}
---

<ArchivePage locale={locale} />
