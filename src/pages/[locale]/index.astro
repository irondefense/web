---
import HomePage from "../../components/home/HomePage.astro";
import { locales, type Locale } from "../../lib/i18n";
import { getLocaleRoot } from "../../lib/routes";
import { siteConfig } from "../../lib/site";

export async function getStaticPaths() {
  return locales.map((locale) => ({
    params: { locale },
    props: { locale },
  }));
}

const { locale } = Astro.props as { locale: Locale };
const englishHomeHref = getLocaleRoot("en");

if (locale === "en") {
  return Astro.redirect(englishHomeHref);
}
---

<HomePage locale={locale} repoUrl={siteConfig.repoUrl} />
