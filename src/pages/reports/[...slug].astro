---
import { getCollection } from "astro:content";
import { buildReportGroups } from "../../lib/reports";

export async function getStaticPaths() {
  const reportGroups = buildReportGroups(
    await getCollection("reports", ({ data }) => !data.draft),
  );

  return reportGroups
    .filter((group) => group.byLang.pl)
    .map((group) => ({
      params: { slug: `${group.reportId}/pl` },
      props: { target: `/pl/raporty/${group.reportId}/` },
    }));
}

return Astro.redirect(Astro.props.target);
---
