---
import { getCollection } from "astro:content";
import type { Locale } from "../../lib/i18n";
import { ui } from "../../lib/i18n";
import { buildReportGroups, getReportForLocale, getReportHref } from "../../lib/reports";
import TopNav from "../home/TopNav.astro";
import LandingLayout from "../../layouts/LandingLayout.astro";

interface Props {
  locale: Locale;
  repoUrl: string;
}

const { locale, repoUrl } = Astro.props;
const t = ui[locale];
const reports = buildReportGroups(await getCollection("reports", ({ data }) => !data.draft));

function formatDate(date: Date) {
  return date.toLocaleDateString(locale === "pl" ? "pl-PL" : "en-GB");
}
---

<LandingLayout title={t.archive.title} description={t.archive.description} locale={locale}>
  <TopNav repoUrl={repoUrl} locale={locale} />

  <style>
    .reports-page {
      padding: 3rem 0 4rem;
    }

    .archive-hero {
      display: grid;
      gap: 1.6rem;
      padding: 2rem 0 2.5rem;
      border-bottom: 1px solid var(--landing-line);
    }

    .archive-kicker {
      display: inline-flex;
      align-items: center;
      gap: 0.9rem;
      margin: 0;
      color: var(--landing-accent);
      font-family: var(--font-mono);
      font-size: 0.96rem;
      letter-spacing: 0.22em;
      text-transform: uppercase;
    }

    .archive-kicker::before {
      content: "";
      width: 2.4rem;
      height: 2px;
      background: var(--landing-accent);
    }

    .archive-heading {
      display: grid;
      gap: 1rem;
      grid-template-columns: minmax(0, 1fr) auto;
      align-items: end;
    }

    .archive-heading h1 {
      margin: 0;
      color: var(--landing-text-strong);
      font-size: clamp(3.2rem, 8vw, 5.4rem);
      line-height: 0.95;
      letter-spacing: -0.05em;
      text-transform: uppercase;
    }

    .archive-count {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-width: 5rem;
      min-height: 5rem;
      color: var(--landing-text-strong);
      font-family: var(--font-display);
      font-size: 1.9rem;
      border: 1px solid var(--landing-line);
      background: rgba(255, 255, 255, 0.025);
    }

    .archive-intro {
      max-width: 46rem;
      margin: 0;
      padding-left: 1.15rem;
      border-left: 3px solid var(--landing-accent);
      font-size: 1.08rem;
      line-height: 1.8;
    }

    .archive-meta {
      display: flex;
      flex-wrap: wrap;
      gap: 0.7rem;
    }

    .meta-pill {
      display: inline-flex;
      align-items: center;
      min-height: 2.3rem;
      padding: 0 0.85rem;
      border: 1px solid var(--landing-line);
      color: var(--landing-text-strong);
      font-family: var(--font-mono);
      font-size: 0.84rem;
      font-weight: 600;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      background: rgba(255, 255, 255, 0.02);
    }

    .reports-grid {
      display: grid;
      gap: 1rem;
      padding-top: 2rem;
    }

    .report-row {
      display: grid;
      gap: 1.1rem;
      grid-template-columns: auto minmax(0, 1fr) auto;
      align-items: start;
      padding: 1.4rem 1.45rem;
      border: 1px solid rgba(158, 184, 201, 0.14);
      background: rgba(38, 42, 48, 0.54);
      transition:
        transform 160ms ease,
        border-color 160ms ease,
        background 160ms ease;
    }

    .report-row:hover {
      transform: translateY(-2px);
      border-color: rgba(158, 184, 201, 0.3);
      background: rgba(45, 49, 56, 0.76);
    }

    .report-index {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-width: 3.4rem;
      min-height: 3.4rem;
      border: 1px solid var(--landing-line);
      color: var(--landing-accent);
      font-family: var(--font-mono);
      font-size: 0.94rem;
      font-weight: 700;
      letter-spacing: 0.14em;
      background: rgba(255, 255, 255, 0.02);
    }

    .report-copy {
      display: grid;
      gap: 0.7rem;
      min-width: 0;
    }

    .report-copy h2 {
      margin: 0;
      color: var(--landing-text-strong);
      font-size: clamp(1.55rem, 3vw, 2.1rem);
      line-height: 1.15;
    }

    .report-copy p {
      margin: 0;
      font-size: 1rem;
      line-height: 1.75;
    }

    .report-tags {
      display: flex;
      flex-wrap: wrap;
      gap: 0.65rem;
    }

    .report-tag {
      display: inline-flex;
      align-items: center;
      min-height: 2rem;
      padding: 0 0.75rem;
      border: 1px solid rgba(158, 184, 201, 0.18);
      color: #c7d3db;
      font-family: var(--font-mono);
      font-size: 0.8rem;
      font-weight: 600;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      background: rgba(255, 255, 255, 0.02);
    }

    .report-side {
      display: grid;
      gap: 0.8rem;
      justify-items: end;
      min-width: 9rem;
    }

    .report-date {
      color: #c7d3db;
      font-family: var(--font-mono);
      font-size: 0.9rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      white-space: nowrap;
    }

    .report-link {
      color: var(--landing-accent);
      font-family: var(--font-mono);
      font-size: 0.92rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    .empty-state {
      padding: 2rem 0 0;
      color: var(--landing-text);
      font-size: 1rem;
      line-height: 1.8;
    }

    @media (max-width: 860px) {
      .archive-heading {
        grid-template-columns: 1fr;
      }

      .report-row {
        grid-template-columns: 1fr;
      }

      .report-index {
        min-width: 3rem;
        min-height: 3rem;
        width: fit-content;
      }

      .report-side {
        justify-items: start;
        min-width: 0;
      }
    }
  </style>

  <main class="reports-page">
    <section class="archive-hero">
      <p class="archive-kicker">{t.archive.kicker}</p>

      <div class="archive-heading">
        <h1>{t.archive.heading}</h1>
        <div class="archive-count">{reports.length}</div>
      </div>

      <p class="archive-intro">{t.archive.intro}</p>

      <div class="archive-meta">
        {t.archive.pills.map((pill) => (
          <span class="meta-pill">{pill}</span>
        ))}
      </div>
    </section>

    {reports.length > 0 ? (
      <section class="reports-grid" aria-label={t.archive.heading}>
        {reports.map((group, index) => {
          const report = getReportForLocale(group, locale);

          return (
            <a class="report-row" href={getReportHref(group.reportId, locale)}>
              <span class="report-index">{String(index + 1).padStart(2, "0")}</span>

              <div class="report-copy">
                <h2>{report.data.title}</h2>
                {report.data.description && <p>{report.data.description}</p>}

                {report.data.tags.length > 0 && (
                  <div class="report-tags">
                    {report.data.tags.map((tag) => (
                      <span class="report-tag">{tag}</span>
                    ))}
                  </div>
                )}
              </div>

              <div class="report-side">
                <span class="report-date">{formatDate(report.data.date)}</span>
                <span class="report-link">{t.archive.open}</span>
              </div>
            </a>
          );
        })}
      </section>
    ) : (
      <p class="empty-state">{t.archive.empty}</p>
    )}
  </main>
</LandingLayout>
