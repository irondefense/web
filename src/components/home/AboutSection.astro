---
import type { Locale } from "../../lib/i18n";
import { ui } from "../../lib/i18n";
import SectionHeading from "../shared/SectionHeading.astro";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = ui[locale].home;
---

<section class="section snap-section" aria-labelledby="about-title">
  <SectionHeading index={t.aboutIndex} title={t.aboutTitle} id="about-title" />

  <div class="about-layout">
    <div class="about-copy">
      <p>{t.aboutP1}</p>
      <p>{t.aboutP2}</p>
      <p class="raw-line">{t.aboutRaw}</p>

      <!-- <div class="stats">
        {t.stats.map((item) => (
          <div class="stat">
            <strong>{item.title}</strong>
            <span>{item.label}</span>
          </div>
        ))}
      </div> -->
    </div>

    <div class="capabilities">
      {t.capabilities.map((item) => (
        <article class="capability">
          <h3>{item.title}</h3>
          <p>{item.description}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .section {
    padding: 5.8rem 0 4.8rem;
    border-top: 1px solid var(--color-line);
  }

  .about-layout {
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(420px, 0.95fr);
    gap: 2.9rem;
    align-items: start;
  }

  .about-copy,
  .capabilities {
    display: grid;
    gap: 0.9rem;
  }

  .about-copy p {
    max-width: 38rem;
    color: var(--color-text);
    font-size: 1.14rem;
    line-height: 1.75;
  }

  .about-copy p + p {
    margin-top: 1rem;
  }

  .raw-line {
    margin-top: 1.5rem !important;
    padding-top: 1rem;
    border-top: 1px solid rgba(158, 184, 201, 0.18);
    color: var(--color-accent) !important;
    font-family: var(--font-mono);
    font-size: 1rem !important;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .stats {
    display: flex;
    flex-wrap: wrap;
    gap: 0.9rem;
    margin-top: 1.8rem;
  }

  .stat,
  .capability {
    position: relative;
  }

  .stat {
    min-width: 160px;
    display: grid;
    gap: 0.3rem;
    padding: 1rem 1.1rem;
    border: 1px solid rgba(158, 184, 201, 0.18);
    background: rgba(36, 40, 47, 0.55);
  }

  .stat::after {
    content: "";
    position: absolute;
    right: -1px;
    bottom: -1px;
    width: 16px;
    height: 16px;
    border-right: 3px solid var(--color-accent);
    border-bottom: 3px solid var(--color-accent);
  }

  .stat strong {
    display: block;
    color: var(--color-text-strong);
    font-family: var(--font-display);
    font-size: 1.1rem;
    text-transform: uppercase;
  }

  .stat span {
    display: block;
    margin-top: 0.15rem;
    color: var(--color-text-muted);
    font-family: var(--font-mono);
    font-size: 0.9rem;
    text-transform: uppercase;
  }

  .capabilities {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .capability {
    min-height: 164px;
    padding: 1.25rem 1.25rem 1.15rem;
    border: 1px solid rgba(158, 184, 201, 0.16);
    background: rgba(36, 40, 47, 0.48);
  }

  .capability::before,
  .capability::after {
    content: "";
    position: absolute;
    width: 16px;
    height: 16px;
  }

  .capability::before {
    top: -1px;
    left: -1px;
    border-top: 3px solid var(--color-accent);
    border-left: 3px solid var(--color-accent);
  }

  .capability::after {
    right: -1px;
    bottom: -1px;
    border-right: 3px solid var(--color-accent);
    border-bottom: 3px solid var(--color-accent);
  }

  .capability h3 {
    margin-bottom: 0.85rem;
    font-size: 1.35rem;
    line-height: 1.1;
    text-transform: uppercase;
  }

  .capability p {
    color: var(--color-text);
    font-size: 1.02rem;
    line-height: 1.65;
  }

  @media (max-width: 900px) {
    .about-layout {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 760px) {
    .section {
      padding: 3.25rem 0 2.75rem;
    }

    .stats {
      display: grid;
      grid-template-columns: 1fr;
    }

    .capabilities {
      grid-template-columns: 1fr;
    }
  }
</style>
