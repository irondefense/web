---
import { Icon } from "astro-icon/components";
import type { Locale } from "../../lib/i18n";
import { ui } from "../../lib/i18n";
import {
  getLocaleRoot,
  getLocaleSwitchPath,
  getLocalizedPath,
} from "../../lib/routes";

interface Props {
  repoUrl: string;
  locale: Locale;
  currentPath?: string;
}

const { repoUrl, locale, currentPath } = Astro.props;
const t = ui[locale].nav;
const homeHref = getLocaleRoot(locale);
const reportsHref = getLocalizedPath(locale, "reports");
const englishHref = getLocaleSwitchPath(currentPath ?? Astro.url.pathname, "en");
const polishHref = getLocaleSwitchPath(currentPath ?? Astro.url.pathname, "pl");
const isReportsPage = (currentPath ?? Astro.url.pathname).startsWith(reportsHref);
---

<header class="topbar" data-topbar-root>
  <a class="brand-lockup" href={homeHref}>
    <span class="brand-name">Irondefence</span>
    <span class="brand-subtitle">{t.subtitle}</span>
  </a>

  <button
    class="menu-toggle"
    type="button"
    aria-expanded="false"
    aria-controls="mobile-drawer"
    aria-label="Open navigation menu"
    data-menu-toggle
  >
    <span></span>
    <span></span>
    <span></span>
  </button>

  <nav class="topnav" aria-label="Primary">
    <div class="topnav-links">
      <a class:list={["nav-link", isReportsPage && "active"]} href={reportsHref}>{t.reports}</a>
    </div>

    <span class="nav-divider" aria-hidden="true"></span>

    <a class="nav-link nav-link-github" href={repoUrl} target="_blank" rel="noreferrer">
      <Icon name="lucide:github" class="nav-link-icon" />
      <span class="nav-link-label">{t.github}</span>
    </a>

    <div class="nav-lang-switch">
      <div class="nav-lang-track">
        <a class:list={["nav-lang-link", locale === "en" && "active"]} href={englishHref}>{t.english}</a>
        <a class:list={["nav-lang-link", locale === "pl" && "active"]} href={polishHref}>{t.polish}</a>
      </div>
    </div>
  </nav>

  <div class="mobile-nav" data-mobile-nav>
    <button class="mobile-overlay" type="button" aria-label="Close navigation menu" data-menu-close></button>

    <aside class="mobile-drawer" id="mobile-drawer" aria-label="Mobile navigation" tabindex="-1">
      <div class="mobile-drawer-head">
        <div class="mobile-brand">
          <span class="brand-name">Irondefence</span>
          <span class="brand-subtitle">{t.subtitle}</span>
        </div>

        <button class="mobile-close" type="button" aria-label="Close navigation menu" data-menu-close>
          <span></span>
          <span></span>
        </button>
      </div>

      <div class="mobile-drawer-body">
        <a class:list={["mobile-link", "primary", isReportsPage && "active"]} href={reportsHref} data-menu-link>{t.reports}</a>
        <a class="mobile-link" href={repoUrl} target="_blank" rel="noreferrer" data-menu-link>
          <Icon name="lucide:github" class="mobile-link-icon" />
          <span>{t.github}</span>
        </a>

        <div class="mobile-lang-switch">
          <span class="mobile-lang-label">{t.language}</span>
          <div class="mobile-lang-links">
            <a class:list={["mobile-lang-link", locale === "en" && "active"]} href={englishHref} data-menu-link>{t.english}</a>
            <a class:list={["mobile-lang-link", locale === "pl" && "active"]} href={polishHref} data-menu-link>{t.polish}</a>
          </div>
        </div>
      </div>
    </aside>
  </div>
</header>

<script is:inline>
  const header = document.querySelector("[data-topbar-root]");

  if (header) {
    const body = document.body;
    const toggle = header.querySelector("[data-menu-toggle]");
    const drawer = header.querySelector("#mobile-drawer");
    const closeButtons = header.querySelectorAll("[data-menu-close], [data-menu-link]");

    const setMenu = (open) => {
      header.dataset.menuOpen = open ? "true" : "false";
      body.classList.toggle("mobile-menu-open", open);

      if (toggle instanceof HTMLButtonElement) {
        toggle.setAttribute("aria-expanded", open ? "true" : "false");
        toggle.setAttribute("aria-label", open ? "Close navigation menu" : "Open navigation menu");
      }

      if (open && drawer instanceof HTMLElement) {
        drawer.focus();
      }
    };

    if (toggle instanceof HTMLButtonElement) {
      toggle.addEventListener("click", () => {
        setMenu(header.dataset.menuOpen !== "true");
      });
    }

    for (const button of closeButtons) {
      button.addEventListener("click", () => setMenu(false));
    }

    window.addEventListener("keydown", (event) => {
      if (event.key === "Escape") {
        setMenu(false);
      }
    });

    const media = window.matchMedia("(min-width: 761px)");
    media.addEventListener("change", (event) => {
      if (event.matches) {
        setMenu(false);
      }
    });
  }
</script>
