---
import { Icon } from "astro-icon/components";
import type { Locale } from "../../lib/i18n";
import { ui } from "../../lib/i18n";
import { getLocalizedPath } from "../../lib/routes";
import SectionHeading from "../shared/SectionHeading.astro";

interface PreviewReport {
  href: string;
  title: string;
  description: string;
  tag: string;
  severity: string;
  tone: "critical" | "high" | "medium";
}

interface Props {
  previewReports: PreviewReport[];
  locale: Locale;
}

const { previewReports, locale } = Astro.props;
const t = ui[locale].home;
const archiveHref = getLocalizedPath(locale, "reports");
---

<section class="section" aria-labelledby="reports-title">
  <div class="reports-head">
    <SectionHeading index={t.reportsIndex} title={t.reportsTitle} id="reports-title" className="reports-heading" />

    <a class="reports-link" href={archiveHref}>{t.allReports}</a>
  </div>

  <p class="reports-copy">{t.reportsIntro}</p>

  <div class="report-grid">
    {
      previewReports.map((report) => (
        <a class:list={["preview-card", `tone-${report.tone}`]} href={report.href}>
          <div class="preview-card-meta">
            <span class="preview-card-tag">{report.tag}</span>
            <span class="preview-card-severity">{report.severity}</span>
          </div>

          <h3 class="preview-card-title">{report.title}</h3>
          <p class="preview-card-desc">{report.description}</p>
          <span class="preview-card-read">{t.readReport}</span>
        </a>
      ))
    }
  </div>

  <div class="reports-cta">
    <a class="button" href={archiveHref}>
      <Icon name="lucide:file-text" class="button-icon" />
      {t.accessAll}
    </a>
  </div>
</section>

<style>
  .section {
    padding: 5.8rem 0 4.8rem;
    border-top: 1px solid var(--color-line);
  }

  .reports-head {
    display: flex;
    justify-content: space-between;
    align-items: end;
    gap: 1.5rem;
    margin-bottom: 0;
  }

  .reports-heading {
    margin-bottom: 0;
  }

  .reports-link {
    color: var(--color-accent);
    font-family: var(--font-mono);
    font-size: 0.98rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .reports-copy {
    max-width: 52rem;
    margin-bottom: 2.1rem;
    padding-left: 1.15rem;
    border-left: 3px solid rgba(158, 184, 201, 0.28);
    font-size: 1.14rem;
    line-height: 1.75;
  }

  .report-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0;
    border: 1px solid rgba(158, 184, 201, 0.15);
  }

  .preview-card {
    display: grid;
    gap: 0;
    min-height: 272px;
    padding: 1.8rem 1.9rem 1.65rem;
    background: rgba(38, 42, 48, 0.62);
    border-right: 1px solid rgba(158, 184, 201, 0.12);
    position: relative;
    transition:
      background 160ms ease,
      transform 160ms ease;
  }

  .preview-card:hover {
    transform: translateY(-2px);
    background: rgba(44, 49, 56, 0.8);
  }

  .preview-card:last-child {
    border-right: 0;
  }

  .preview-card::before {
    content: "";
    position: absolute;
    inset: 0 auto 0 0;
    width: 5px;
  }

  .preview-card-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.9rem;
    align-items: center;
    margin-bottom: 1.4rem;
  }

  .preview-card-tag,
  .preview-card-severity,
  .preview-card-read {
    display: inline-flex;
    align-items: center;
    min-height: 32px;
    padding: 0 0.75rem;
    border: 1px solid currentColor;
    font-family: var(--font-mono);
    font-size: 0.9rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .preview-card-read {
    display: inline-block;
    min-height: auto;
    padding: 0;
    margin-top: 1.55rem;
    border: 0;
    color: #89a5ba;
  }

  .preview-card-read:hover {
    color: var(--color-text-strong);
  }

  .preview-card-title {
    margin-bottom: 1rem;
    font-size: 1.75rem;
    line-height: 1.24;
  }

  .preview-card-desc {
    color: var(--color-text);
    font-size: 1.04rem;
    line-height: 1.7;
  }

  .tone-critical::before {
    background: var(--color-critical);
  }

  .tone-high::before {
    background: var(--color-high);
  }

  .tone-medium::before {
    background: var(--color-medium);
  }

  .tone-critical .preview-card-tag,
  .tone-critical .preview-card-severity {
    color: var(--color-critical);
  }

  .tone-high .preview-card-tag,
  .tone-high .preview-card-severity {
    color: var(--color-high);
  }

  .tone-medium .preview-card-tag,
  .tone-medium .preview-card-severity {
    color: var(--color-medium);
  }

  .reports-cta {
    display: flex;
    justify-content: center;
    margin-top: 2.2rem;
  }

  @media (max-width: 960px) {
    .report-grid {
      grid-template-columns: 1fr;
      gap: 1px;
      background: rgba(158, 184, 201, 0.15);
    }

    .preview-card {
      border-right: 0;
    }
  }

  @media (max-width: 760px) {
    .section {
      padding: 3.25rem 0 2.75rem;
    }

    .reports-head {
      display: grid;
      grid-template-columns: 1fr;
      align-items: start;
    }
  }
</style>
