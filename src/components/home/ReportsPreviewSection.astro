---
import { Icon } from "astro-icon/components";
import type { Locale } from "../../lib/i18n";
import { ui } from "../../lib/i18n";
import { getLocalizedPath } from "../../lib/routes";

interface PreviewReport {
  href: string;
  title: string;
  description: string;
  tag: string;
  severity: string;
  tone: "critical" | "high" | "medium";
}

interface Props {
  previewReports: PreviewReport[];
  locale: Locale;
}

const { previewReports, locale } = Astro.props;
const t = ui[locale].home;
const archiveHref = getLocalizedPath(locale, "reports");
---

<section class="section" aria-labelledby="reports-title">
  <div class="reports-head">
    <div class="section-head" style="margin-bottom: 0;">
      <p class="section-index">{t.reportsIndex}</p>
      <h2 class="section-title" id="reports-title">{t.reportsTitle}</h2>
    </div>

    <a class="reports-link" href={archiveHref}>{t.allReports}</a>
  </div>

  <p class="reports-copy">{t.reportsIntro}</p>

  <div class="report-grid">
    {
      previewReports.map((report) => (
        <a class:list={["report-card", report.tone]} href={report.href}>
          <div class="report-meta">
            <span class="tag">{report.tag}</span>
            <span class="severity">{report.severity}</span>
          </div>

          <h3 class="report-title">{report.title}</h3>
          <p class="report-desc">{report.description}</p>
          <span class="report-read">{t.readReport}</span>
        </a>
      ))
    }
  </div>

  <div class="reports-cta">
    <a class="button" href={archiveHref}>
      <Icon name="lucide:file-text" class="button-icon" />
      {t.accessAll}
    </a>
  </div>
</section>
