---
interface Props {
  repoUrl: string;
}

const { repoUrl } = Astro.props;
---

<section class="hero" aria-labelledby="hero-title">
  <div class="hero-copy">
    <p class="hero-kicker">Cyber Threat Intelligence</p>
    <h1 class="wordmark" id="hero-title" aria-label="irondefence">
      <span class="wordmark-base">
        <span class="wordmark-piece">iron</span>
        <span class="wordmark-piece">defence</span>
      </span>
      <span class="wordmark-layer wordmark-layer-a" aria-hidden="true">
        <span class="wordmark-piece">iron</span>
        <span class="wordmark-piece">defence</span>
      </span>
      <span class="wordmark-layer wordmark-layer-b" aria-hidden="true">
        <span class="wordmark-piece">iron</span>
        <span class="wordmark-piece">defence</span>
      </span>
    </h1>
    <p class="role">Malware Analyst / CTI Researcher</p>
    <p class="hero-desc">
      Tracking adversaries. Dissecting malware. Publishing open-source threat intelligence to
      help defenders stay ahead.
    </p>

    <div class="hero-actions">
      <a class="button secondary" href={repoUrl} target="_blank" rel="noreferrer">
        <svg viewBox="0 0 24 24" aria-hidden="true" fill="currentColor">
          <path
            d="M12 2C6.477 2 2 6.589 2 12.248c0 4.527 2.865 8.368 6.839 9.724.5.096.682-.221.682-.493 0-.243-.009-.888-.014-1.742-2.782.615-3.369-1.384-3.369-1.384-.455-1.177-1.11-1.491-1.11-1.491-.908-.635.069-.622.069-.622 1.004.072 1.532 1.053 1.532 1.053.892 1.562 2.341 1.111 2.91.849.091-.667.349-1.112.635-1.367-2.221-.258-4.555-1.138-4.555-5.065 0-1.119.39-2.034 1.029-2.751-.103-.259-.446-1.301.098-2.712 0 0 .84-.276 2.75 1.05A9.326 9.326 0 0 1 12 6.836a9.28 9.28 0 0 1 2.504.349c1.909-1.326 2.747-1.05 2.747-1.05.546 1.411.203 2.453.1 2.712.64.717 1.027 1.632 1.027 2.751 0 3.938-2.338 4.804-4.566 5.057.359.319.679.949.679 1.913 0 1.381-.012 2.495-.012 2.834 0 .274.18.593.688.492A10.252 10.252 0 0 0 22 12.248C22 6.589 17.523 2 12 2Z"
          />
        </svg>
        /irondefence
      </a>

      <a class="button" href="/reports/">
        <svg viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="1.8">
          <path d="M6 3.75h8.5L19 8.25V19.5A1.5 1.5 0 0 1 17.5 21h-11A1.5 1.5 0 0 1 5 19.5V5.5A1.5 1.5 0 0 1 6.5 4Z"></path>
          <path d="M14 3.75V8.5h4.75"></path>
          <path d="M8 12.5h8"></path>
          <path d="M8 16h5"></path>
        </svg>
        View reports
      </a>
    </div>
  </div>
</section>
