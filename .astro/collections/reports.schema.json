{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "reportId": {
      "type": "string"
    },
    "lang": {
      "type": "string",
      "enum": [
        "en",
        "pl"
      ]
    },
    "title": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "date": {
      "type": "string",
      "format": "date-time"
    },
    "draft": {
      "default": false,
      "type": "boolean"
    },
    "tlp": {
      "default": "clear",
      "type": "string",
      "enum": [
        "clear",
        "green",
        "amber",
        "red"
      ]
    },
    "tags": {
      "default": [],
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "reportId",
    "lang",
    "title",
    "date",
    "draft",
    "tlp",
    "tags"
  ],
  "additionalProperties": false
}